{
  "name": "jpmt-tracking-server",
  "version": "1.0.0",
  "description": "JPMT Logistics - Production-ready shipment tracking system",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "db:migrate": "ts-node src/database/migrate.ts",
    "db:seed": "ts-node src/database/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "bull": "^4.12.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "twilio": "^4.19.0",
    "nodemailer": "^6.9.7",
    "web-push": "^3.6.6",
    "axios": "^1.6.2",
    "prom-client": "^15.1.0",
    "compression": "^1.7.4",
    "hpp": "^0.2.3",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/hpp": "^0.2.6",
    "@types/pg": "^8.10.9",
    "@types/nodemailer": "^6.4.14",
    "@types/web-push": "^3.6.3",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "logistics",
    "tracking",
    "shipment",
    "real-time",
    "notifications",
    "sse"
