# ============================================
# JPMT Tracking Server - Environment Configuration
# ============================================

# Server Configuration
NODE_ENV=development
PORT=3001
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://jpmt_user:jpmt_password@localhost:5432/jpmt_tracking
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jpmt_tracking
DB_USER=jpmt_user
DB_PASSWORD=jpmt_password
DB_SSL=false
DB_POOL_SIZE=20

# Redis (Cache + Queue)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Security
API_KEY_SECRET=your-super-secret-api-key-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_API_KEY=1000

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# Carrier API Keys (Optional for demo)
DHL_API_KEY=
DHL_API_SECRET=
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
UPS_ACCESS_KEY=
UPS_USER_ID=
UPS_PASSWORD=
USPS_USER_ID=

# Notification Services
# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@jpmtlogistics.com

# Web Push
WEB_PUSH_VAPID_PUBLIC=
WEB_PUSH_VAPID_PRIVATE=
WEB_PUSH_SUBJECT=mailto:support@jpmtlogistics.com

# Mapbox (Maps)
MAPBOX_ACCESS_TOKEN=

# Google Maps (Distance Matrix API for ETA)
GOOGLE_MAPS_API_KEY=

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_ENABLED=true

# Feature Flags
ENABLE_SSE=true
ENABLE_NOTIFICATIONS=true
ENABLE_CARRIER_INTEGRATION=false
ENABLE_MOCK_DATA=true
